# Default registry for public packages
registry=https://registry.npmjs.org/

# Syndicate matchmaker SDK — Foundry Artifacts npm repository (requires auth token)
@syndicate-matchmaker:registry=https://racer.usw-18.palantirfoundry.com/artifacts/api/repositories/ri.artifacts.main.repository.73d53979-4c48-495b-862a-7702e5b5946d/contents/release/npm/

# Authenticate: create a Foundry token with artifacts read, then either:
#   export NPM_CONFIG_TOKEN="your-token"
#   npm config set //racer.usw-18.palantirfoundry.com/artifacts/api/repositories/ri.artifacts.main.repository.73d53979-4c48-495b-862a-7702e5b5946d/contents/release/npm/:_authToken "${NPM_CONFIG_TOKEN}" --location project
# Or add the _authToken line below (do not commit real tokens).
# //racer.usw-18.palantirfoundry.com/artifacts/api/repositories/ri.artifacts.main.repository.73d53979-4c48-495b-862a-7702e5b5946d/contents/release/npm/:_authToken=${NPM_CONFIG_TOKEN}
