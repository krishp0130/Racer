# Palantir Foundry — Racer stack (usw-18)
# Copy to `.env.local` and adjust redirect if your OAuth app uses a different callback.

FOUNDRY_URL=https://racer.usw-18.palantirfoundry.com
FOUNDRY_CLIENT_ID=ff98fc193d15a16f5b1de711bc8d1922

# OAuth callback (must match the redirect URL registered on your Foundry OAuth client)
FOUNDRY_REDIRECT_URI=http://localhost:3000/auth/callback

# Optional — defaults include AIP Agents scopes
# FOUNDRY_OAUTH_SCOPES=offline_access api:aip-agents-read api:aip-agents-write

# Optional — default agent RID is in src/lib/aipAgentConfig.ts
# AIP_AGENT_RID=ri.aip-agents..agent.e2ae4892-a7fa-438b-a903-814d0cbe8102
